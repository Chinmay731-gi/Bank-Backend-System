<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>NeoBank Dashboard</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gradient-to-br from-blue-900 via-indigo-800 to-purple-800 min-h-screen text-white">

<nav class="flex justify-between items-center px-10 py-5">
    <h1 class="text-2xl font-bold">💳 NeoBank</h1>

    <a href="/api/auth/logout"
       class="bg-red-500 hover:bg-red-600 px-4 py-2 rounded-lg font-semibold">
       Logout
    </a>
</nav>

<section class="px-6 md:px-20 py-10">

    <div class="bg-white/10 backdrop-blur-lg p-8 rounded-2xl shadow-xl mb-10">
        <h2 class="text-3xl font-bold mb-2">
            Welcome back,
            <% if (user) { %>
                <span class="text-yellow-400"><%= user.name %></span>
            <% } %>
        </h2>
    </div>

    <h3 class="text-2xl font-semibold mb-6">Your Accounts</h3>

    <div class="grid md:grid-cols-2 gap-8">

        <% accounts.forEach(account => { %>

        <div class="bg-white/10 backdrop-blur-lg p-6 rounded-2xl shadow-lg">

            <h4 class="text-xl font-bold mb-2">Account Number</h4>
            <p class="text-gray-300 text-sm mb-4">
                <%= account.number %>
            </p>

            <div id="balance-<%= account._id %>" class="mb-4 hidden">
                <div class="bg-white/20 p-3 rounded-lg">
                    <p class="text-sm text-gray-300">Current Balance:</p>
                    <p class="text-2xl font-bold text-green-400"
                       id="balance-amount-<%= account._id %>">₹ 0.00</p>
                </div>
            </div>

            <div class="flex gap-4 mt-4">
                <button onclick="checkBalance('<%= account._id %>')"
                        class="bg-green-500 hover:bg-green-600 px-4 py-2 rounded-lg font-semibold">
                    Check Balance
                </button>

                <button onclick="toggleTransferForm('<%= account._id %>')"
                        class="bg-blue-500 hover:bg-blue-600 px-4 py-2 rounded-lg font-semibold">
                    Transfer
                </button>
            </div>
            
            <div id="transfer-form-<%= account._id %>"
                 class="hidden mt-6 bg-white/10 p-4 rounded-xl border border-white/20">

                <form onsubmit="submitTransfer(event, '<%= account.number %>', '<%= account._id %>')">

                    <div class="mb-3">
                        <label class="text-sm text-gray-300">Receiver Account Number</label>
                        <input type="text"
                               id="receiver-<%= account._id %>"
                               required
                               class="w-full mt-1 p-2 rounded bg-white/20 text-white outline-none">
                    </div>

                    <div class="mb-3">
                        <label class="text-sm text-gray-300">Amount (₹)</label>
                        <input type="number"
                               step="0.01"
                               id="amount-<%= account._id %>"
                               required
                               class="w-full mt-1 p-2 rounded bg-white/20 text-white outline-none">
                    </div>

                    <input type="hidden"
                           id="idempotency-<%= account._id %>">

                    <button type="submit"
                            class="w-full bg-purple-500 hover:bg-purple-600 py-2 rounded-lg font-semibold">
                        Confirm Transfer
                    </button>

                    <p id="transfer-message-<%= account._id %>"
                       class="text-sm mt-3"></p>

                </form>
            </div>

        </div>

        <% }) %>

    </div>

</section>

<footer class="text-center text-gray-300 py-6 text-sm mt-10">
    © 2026 NeoBank
</footer>

<script>

async function checkBalance(accountId) {
    const balanceDiv = document.getElementById(`balance-${accountId}`);
    const balanceAmount = document.getElementById(`balance-amount-${accountId}`);

    balanceDiv.classList.remove("hidden");
    balanceAmount.textContent = "Loading...";

    try {
        const res = await fetch(`/api/account/balance/${accountId}`);
        const data = await res.json();
        balanceAmount.textContent = `₹${data.balance.toFixed(2)}`;
    } catch {
        balanceAmount.textContent = "Error";
    }
}

function toggleTransferForm(accountId) {
    const form = document.getElementById(`transfer-form-${accountId}`);
    const keyInput = document.getElementById(`idempotency-${accountId}`);

    form.classList.toggle("hidden");

    if (!form.classList.contains("hidden")) {
        keyInput.value = crypto.randomUUID();
    }
}

async function submitTransfer(event, fromAccountNumber, accountId) {
    event.preventDefault();

    const receiver = document.getElementById(`receiver-${accountId}`).value;
    const amount = document.getElementById(`amount-${accountId}`).value;
    const idempotencyKey = document.getElementById(`idempotency-${accountId}`).value;
    const messageEl = document.getElementById(`transfer-message-${accountId}`);

    messageEl.textContent = "Processing...";
    messageEl.className = "text-yellow-300 text-sm mt-3";

    try {
        const res = await fetch("/api/transaction", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
                fromAccountNumber,
                toAccountNumber: receiver,
                amount: parseFloat(amount),
                idempotencyKey
            })
        });

        const data = await res.json();

        if (!res.ok) throw new Error(data.message);

        messageEl.textContent = "Transfer successful ✅";
        messageEl.className = "text-green-400 text-sm mt-3";

    } catch (err) {
        messageEl.textContent = err.message;
        messageEl.className = "text-red-400 text-sm mt-3";
    }
}

</script>

</body>
</html>